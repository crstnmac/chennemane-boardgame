{
  "name": "chennamane-pear",
  "productName": "Chennamane Pear",
  "version": "0.1.0",
  "upgrade": "pear://<YOUR_KEY_HERE>",
  "description": "Ali Guli Mane desktop multiplayer — full Pear product (pear-runtime, Bare worker, Hyperswarm P2P, OTA).",
  "license": "MIT",
  "author": "Chennamane",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "build:engine": "node scripts/bundle-engine.js",
    "prestart": "node scripts/bundle-engine.js",
    "pretest": "node scripts/bundle-engine.js",
    "dev": "node scripts/bundle-engine.js && node scripts/dev-electron.js",
    "dev:electron-only": "node scripts/bundle-engine.js && electron . --no-updates --dev",
    "start": "electron-forge start -- --no-updates",
    "start:updates": "electron-forge start -- --updates",
    "package": "npm run build:engine && electron-forge package",
    "make": "npm run build:engine && electron-forge make",
    "test": "node --test tests/*.test.js",
    "lint": "node --check electron/main.js && node --check electron/preload.js && node --check workers/main.js && node --check workers/session.js && node --check workers/protocol.js && node --check workers/room.js"
  },
  "dependencies": {
    "b4a": "^1.6.7",
    "bare-path": "^3.1.1",
    "bare-storage": "^1.1.0",
    "corestore": "^7.11.0",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hypercore-crypto": "^3.4.2",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.3.1",
    "which-runtime": "^1.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^33.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "esbuild": "^0.25.0",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-link": "^2.0.1"
  },
  "allowScripts": {
    "electron": true
  }
}
